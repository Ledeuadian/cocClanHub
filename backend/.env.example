# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
# Set to your Render URL, e.g.:
#   CLIENT_URL=https://your-api.onrender.com
CLIENT_URL=http://localhost:5173

# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY-HERE

# ── Clash of Clans API ────────────────────────────────────
# Get your key at https://developer.clashofclans.com/
# ⚠️ Whitelist your server's IP (Render's egress IP) in the Supercell dashboard.
COC_API_TOKEN=YOUR-TOKEN-HERE
# MUST be wrapped in quotes — the # starts a comment in .env files!
COC_CLAN_TAG="#YOUR-CLAN-TAG"

# ── Admin authentication ─────────────────────────────────────
# Admins are regular Supabase users with is_admin = TRUE in their
# profiles row. No shared secret needed — just promote users in the
# Supabase SQL Editor:
#   UPDATE profiles SET is_admin = TRUE WHERE email = 'your@email.com';
# (no env variable required)