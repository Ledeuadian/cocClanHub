# ── Supabase (REQUIRED for real auth) ───────────────────────────
# 1. Go to https://supabase.com/dashboard → select your project
# 2. Click the gear icon (⚙) → "Project Settings" → "API"
# 3. Copy these values:
#
#    "Project URL"  →  VITE_SUPABASE_URL
#       (looks like: https://abcdefghijkl.supabase.co)
#       ⚠️ Do NOT add /rest/v1/ at the end — the app adds it automatically
#
#    "anon public" key  →  VITE_SUPABASE_ANON_KEY
#       (long JWT starting with eyJ...)
#       ✅ This one is SAFE to use in the frontend
#       It only has the permissions you grant via Row Level Security

VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF6bmx5amhtZGZmZXJ4eXRmZHhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM2NDQzOTIsImV4cCI6MjA5OTIyMDM5Mn0.ebe9KfJSGV_MHb0MNtVXbdSIeP3CGvHRO-pPNCy5vbY
SUPABASE_URL=https://qznlyjhmdfferxytfdxc.supabase.co/rest/v1/
SUPABASE_SERVICE_KEY = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF6bmx5amhtZGZmZXJ4eXRmZHhjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzY0NDM5MiwiZXhwIjoyMDk5MjIwMzkyfQ.Q3wQ4X5rHm4bNUFwMFIld4xMsto6yAvHnpkggnwKYUc
# ── Backend (Express API) ───────────────────────────────────────
# Use a RELATIVE URL so the app works on any device (desktop, phone, production).
# Vite's dev proxy forwards /api → http://localhost:5000 automatically.
# In production, set this to https://yourdomain.com/api
VITE_API_URL=/api
VITE_SOCKET_URL=

# ── COC API (for reference only — token stays on backend) ──────
VITE_COC_API_BASE=https://api.clashofclans.com/v1