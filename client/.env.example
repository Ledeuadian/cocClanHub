# ── Supabase (REQUIRED for real auth) ───────────────────────────
# 1. Go to https://supabase.com/dashboard → select your project
# 2. Click the gear icon (⚙) → "Project Settings" → "API"
# 3. Copy these values:
#
#    "Project URL"  →  VITE_SUPABASE_URL
#       (looks like: https://abcdefghijkl.supabase.co)
#       ⚠️ Do NOT add /rest/v1/ at the end — the app adds it automatically
#
#    "anon public" key  →  VITE_SUPABASE_ANON_KEY
#       (long JWT starting with eyJ...)
#       ✅ This one is SAFE to use in the frontend
#       It only has the permissions you grant via Row Level Security

VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY-HERE

# ── Backend (Express API) ───────────────────────────────────────
# Use a RELATIVE URL so the app works on any device (desktop, phone, production).
# Vite's dev proxy forwards /api → http://localhost:5000 automatically.
# In production, set this to your backend's URL, e.g.
#   VITE_API_URL=https://your-api.onrender.com/api
#   VITE_SOCKET_URL=https://your-api.onrender.com
VITE_API_URL=/api
VITE_SOCKET_URL=

# ── COC API (for reference only — token stays on backend) ──────
VITE_COC_API_BASE=https://api.clashofclans.com/v1